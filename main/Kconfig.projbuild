menu "ESP32 Scope"

config SCOPE_SAMPLE_RATE_HZ
    int "ADC sample rate (samples/second)"
    range 20000 2000000
    default 200000
    help
        Continuous ADC conversion rate. 200 kSa/s is a practical fast
        default when samples are streamed over Wi-Fi.

config SCOPE_WIFI_SSID
    string "Wi-Fi SSID"
    default ""

config SCOPE_WIFI_PASSWORD
    string "Wi-Fi password"
    default ""

config SCOPE_MDNS_HOSTNAME
    string "Local network hostname"
    default "esp32scope"
    help
        Hostname advertised over mDNS. Open the web interface at
        http://<hostname>.local/ from a device on the same network.

endmenu
